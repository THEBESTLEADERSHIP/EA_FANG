-- Sticky attach helper with specific animations
local function startStickyMode(button, getTargetPart, getPlayerCFrame, animId)
	local running = true
	local wasVoid = VoidProtection_Button.Ticket_Asset.ImageColor3 == Color3.fromRGB(0,255,0)
	if not wasVoid then ToggleVoidProtection(true) end
	
	if animId then
		PlayAnim(animId, 0, 1)
	end
	
	local connection
	connection = RunService.RenderStepped:Connect(function()
		if not running or button.Ticket_Asset.ImageColor3 == Color3.fromRGB(255,0,0) then
			running = false
			connection:Disconnect()
			StopAnim()
			if not wasVoid then ToggleVoidProtection(false) end
			return
		end
		pcall(function()
			local target = Players[TargetedPlayer]
			if not target or not target.Character then return end
			local part = getTargetPart(target)
			if not part then return end
			local root = GetRoot(plr)
			if not root then return end
			root.CFrame = getPlayerCFrame(part)
			root.Velocity = Vector3.new(0,0,0)
			plr.Character.Humanoid.PlatformStand = true
		end)
	end)
end

